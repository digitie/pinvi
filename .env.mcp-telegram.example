# mcp-telegram credential (per-worktree, LOCAL ONLY).
#
# 실제 값은 `.env.mcp-telegram`(gitignore됨)에 둔다. 이 파일은 형식 예시일 뿐
# credential을 담지 않는다. tracked 설정/문서에 토큰을 절대 쓰지 않는다.
#
# mcp-telegram(Telethon 기반)은 Telegram 앱의 API_ID/API_HASH로 동작한다.
# https://my.telegram.org → API development tools 에서 발급.
# 최초 1회 로그인(인증번호/2FA)은 사람이 실행한다:
#   C:\Python314\python.exe scripts\mcp_telegram_start.py login
#
# 기존 worktree(예: F:\dev\kor-travel-map-claude\.env.mcp-telegram)의
# credential/세션을 재사용할 수 있다(같은 API_ID/API_HASH).

API_ID=<telegram-api-id>
API_HASH=<telegram-api-hash>
# 선택: 알림을 보낼 기본 chat/user/channel 식별자
# TELEGRAM_NOTIFY_CHAT=<chat-id-or-username>
