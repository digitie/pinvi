# TripMate v2 환경변수 예시
# 운영 / staging 값은 별도 secret 저장소. 본 파일은 키 이름 + 안전한 기본값만.

# ─────────────────────────────────────────────────────────────
# 0. Local dev fixed ports
# ─────────────────────────────────────────────────────────────
TRIPMATE_API_DEV_PORT=12501
TRIPMATE_WEB_DEV_PORT=12505
TRIPMATE_DAGSTER_DEV_PORT=9023

# ─────────────────────────────────────────────────────────────
# 1. 인증 / JWT
# ─────────────────────────────────────────────────────────────
TRIPMATE_JWT_SECRET_KEY=tripmate-local-jwt-secret-change-me
TRIPMATE_ACCESS_TOKEN_MINUTES=15
TRIPMATE_REFRESH_TOKEN_DAYS=7
TRIPMATE_ADMIN_SESSION_TTL=3600
TRIPMATE_MCP_JWT_SECRET=tripmate-local-mcp-secret-change-me
TRIPMATE_MCP_TOKEN_DEFAULT_DAYS=30
TRIPMATE_MCP_RATE_LIMIT_PER_MINUTE=60

# ─────────────────────────────────────────────────────────────
# 2. Database
# ─────────────────────────────────────────────────────────────
# 로컬: 5432 host port (compose) → 5432 컨테이너 internal
TRIPMATE_DATABASE_URL=postgresql+asyncpg://tripmate:tripmate_dev_password@localhost:5432/tripmate
TRIPMATE_DATABASE_POOL_SIZE=10

# ─────────────────────────────────────────────────────────────
# 3. Resend (이메일)
# ─────────────────────────────────────────────────────────────
# 빈 값이면 콘솔 출력 모드 — 가입은 성공하지만 verification_email_dispatched=false
TRIPMATE_RESEND_API_KEY=
TRIPMATE_RESEND_FROM_EMAIL=TripMate <noreply@send.tripmate.local>
TRIPMATE_RESEND_TIMEOUT_SECONDS=5
TRIPMATE_RESEND_WEBHOOK_SECRET=
# 기본 false(안전). 로컬에서 서명 없이 테스트할 때만 true로. 운영/스테이징은 false 유지.
TRIPMATE_RESEND_WEBHOOK_ALLOW_UNSIGNED=false
TRIPMATE_WEB_BASE_URL=http://localhost:12505
# production: TRIPMATE_WEB_BASE_URL=https://tripmate.digitie.mywire.org
TRIPMATE_EMAIL_VERIFICATION_PATH=/verify-email
TRIPMATE_PASSWORD_RESET_PATH=/reset-password

# ─────────────────────────────────────────────────────────────
# 4. OAuth (소셜 로그인 — 현재 Google만 사용, Naver/Kakao는 미래 작업)
# ─────────────────────────────────────────────────────────────
TRIPMATE_GOOGLE_OAUTH_CLIENT_ID=
TRIPMATE_GOOGLE_OAUTH_CLIENT_SECRET=
# 현재 `/auth/oauth/providers`는 Google만 반환한다. 아래 값은 미래 provider
# 구현 전까지 설정해도 사용하지 않는다.
TRIPMATE_NAVER_OAUTH_CLIENT_ID=
TRIPMATE_NAVER_OAUTH_CLIENT_SECRET=
TRIPMATE_KAKAO_OAUTH_REST_API_KEY=
TRIPMATE_KAKAO_OAUTH_CLIENT_SECRET=
TRIPMATE_OAUTH_CALLBACK_BASE_URL=http://localhost:12501
# production: TRIPMATE_OAUTH_CALLBACK_BASE_URL=https://tripmateapi.digitie.mywire.org
TRIPMATE_OAUTH_STATE_TTL_SECONDS=600
TRIPMATE_OAUTH_HTTP_TIMEOUT_SECONDS=5

# ─────────────────────────────────────────────────────────────
# 5. RustFS (S3 호환 객체 저장소)
# ─────────────────────────────────────────────────────────────
TRIPMATE_RUSTFS_PORT=12101
TRIPMATE_RUSTFS_CONSOLE_PORT=12105
TRIPMATE_RUSTFS_ENDPOINT_URL=http://localhost:12101
TRIPMATE_RUSTFS_PUBLIC_ENDPOINT_URL=http://127.0.0.1:12101
TRIPMATE_RUSTFS_BUCKET=tripmate-media
TRIPMATE_RUSTFS_ACCESS_KEY_ID=rustfsadmin
TRIPMATE_RUSTFS_SECRET_ACCESS_KEY=rustfsadmin
TRIPMATE_RUSTFS_PRESIGNED_URL_EXPIRES_SECONDS=900
TRIPMATE_RUSTFS_MAX_UPLOAD_BYTES=10485760
TRIPMATE_RUSTFS_ALLOWED_CONTENT_TYPES=["image/jpeg","image/png","image/webp","image/gif","video/mp4","application/pdf"]
TRIPMATE_RUSTFS_PUBLIC_BASE_URL=

# ─────────────────────────────────────────────────────────────
# 6. krtour-map 독립 프로그램 (지도 feature OpenAPI/Admin)
# ─────────────────────────────────────────────────────────────
TRIPMATE_KRTOUR_MAP_API_BASE_URL=http://localhost:12301
# admin feature change(/v1/admin/features*)도 같은 호스트 :12301
TRIPMATE_KRTOUR_MAP_ADMIN_BASE_URL=http://localhost:12301
# 운영 인증은 인프라 계층. 설정 시 X-Krtour-Service-Token 헤더로 전달.
TRIPMATE_KRTOUR_MAP_SERVICE_TOKEN=
# admin-path 전용 토큰(미설정 시 위 SERVICE_TOKEN fallback). §7 admin 인증 합의 대기.
TRIPMATE_KRTOUR_MAP_ADMIN_SERVICE_TOKEN=
TRIPMATE_KRTOUR_MAP_TIMEOUT_SECONDS=5
TRIPMATE_KRTOUR_MAP_MAX_ATTEMPTS=3
TRIPMATE_KRTOUR_MAP_BATCH_CHUNK_SIZE=200

# ─────────────────────────────────────────────────────────────
# 6-1. tripmate-agent 독립 프로그램 (후속 외부 연계)
# ─────────────────────────────────────────────────────────────
TRIPMATE_AGENT_API_BASE_URL=http://localhost:12401

# ─────────────────────────────────────────────────────────────
# 7. KASI / data.go.kr (TripMate Dagster)
# ─────────────────────────────────────────────────────────────
DATA_GO_KR_SERVICE_KEY=
TRIPMATE_KASI_SPECIAL_DAYS_LOOKBACK_MONTHS=6
TRIPMATE_KASI_SPECIAL_DAYS_LOOKAHEAD_MONTHS=18

# ─────────────────────────────────────────────────────────────
# 8. Sentry (에러 / 성능)
# ─────────────────────────────────────────────────────────────
TRIPMATE_SENTRY_DSN=
TRIPMATE_SENTRY_ENVIRONMENT=development
TRIPMATE_SENTRY_RELEASE=
TRIPMATE_SENTRY_TRACES_SAMPLE_RATE=0.1
TRIPMATE_SENTRY_PROFILES_SAMPLE_RATE=0.0

# ─────────────────────────────────────────────────────────────
# 9. CORS
# ─────────────────────────────────────────────────────────────
# JSON 배열 — 빈 값이면 dev 기본값(localhost:12505) 사용
TRIPMATE_CORS_ALLOWED_ORIGINS=["http://localhost:12505","http://127.0.0.1:12505"]
# production: TRIPMATE_CORS_ALLOWED_ORIGINS=["https://tripmate.digitie.mywire.org"]

# ─────────────────────────────────────────────────────────────
# 10. Geofencing (ADR-018, FastAPI 3차 fallback)
# ─────────────────────────────────────────────────────────────
TRIPMATE_GEOFENCE_ENABLED=false
TRIPMATE_GEOFENCE_ALLOWED_COUNTRIES=["KR"]
TRIPMATE_GEOFENCE_COUNTRY_HEADER=CF-IPCountry
TRIPMATE_GEOFENCE_TRUSTED_PROXY_HEADER=X-TripMate-Geofence-Proxy
TRIPMATE_GEOFENCE_TRUSTED_PROXY_SECRET=
TRIPMATE_GEOFENCE_TRUSTED_PROXY_CIDRS=[]
TRIPMATE_GEOFENCE_MTLS_VERIFIED_HEADER=
TRIPMATE_GEOFENCE_MTLS_VERIFIED_VALUE=SUCCESS
TRIPMATE_GEOFENCE_BLOCK_UNKNOWN=false
TRIPMATE_GEOFENCE_BYPASS_PATHS=["/health","/health/db","/docs","/redoc","/openapi.json"]

# ─────────────────────────────────────────────────────────────
# 11. Backup / Restore (ADR-022, app schema snapshot)
# ─────────────────────────────────────────────────────────────
TRIPMATE_BACKUP_DIR=.tmp/backups
TRIPMATE_BACKUP_SCRIPT_PATH=scripts/backup-db.sh
TRIPMATE_RESTORE_SCRIPT_PATH=scripts/restore-db.sh
TRIPMATE_RESTORE_HOTSWAP_SCRIPT_PATH=scripts/restore-hotswap.sh
TRIPMATE_BACKUP_TIMEOUT_SECONDS=900
TRIPMATE_RESTORE_TIMEOUT_SECONDS=3600
TRIPMATE_BACKUP_SCHEMA=app
TRIPMATE_RESTORE_DATABASE_URL=
# 실제 schema-swap 실행은 staging drill 후 운영 노드에서만 1로 둔다.
TRIPMATE_RESTORE_HOTSWAP_EXECUTE=0
TRIPMATE_RESTORE_DRAIN_COMMAND=
TRIPMATE_RESTORE_ALLOW_NO_DRAIN=0
TRIPMATE_RESTORE_APP_ROLE=

# ─────────────────────────────────────────────────────────────
# 12. Frontend (apps/web, NEXT_PUBLIC_* 는 빌드 시 embed)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_TRIPMATE_API_URL=http://localhost:12501
# production build: NEXT_PUBLIC_TRIPMATE_API_URL=https://tripmateapi.digitie.mywire.org
NEXT_PUBLIC_TRIPMATE_ENV=development
NEXT_PUBLIC_VWORLD_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3002
NEXT_PUBLIC_GRAFANA_DASHBOARD_PATH=/d/tripmate/overview?orgId=1&kiosk=tv

# ─────────────────────────────────────────────────────────────
# 13. Bootstrap admin (선택)
# ─────────────────────────────────────────────────────────────
TRIPMATE_BOOTSTRAP_ADMIN_EMAIL=admin@ad.min
TRIPMATE_BOOTSTRAP_ADMIN_PASSWORD=admin

# ─────────────────────────────────────────────────────────────
# 14. Feature flags
# ─────────────────────────────────────────────────────────────
TRIPMATE_ENABLE_SEED=false
TRIPMATE_ENVIRONMENT=development
