# Pinvi 운영(prod) env 템플릿 — placeholder만. 실제 값은 `infra/.env.prod`(gitignore)에 둔다.
# 공개 repo에는 실제 도메인/시크릿을 커밋하지 않는다(ADR-047).
#
# 사용:
#   cp infra/.env.prod.example infra/.env.prod   # 후 실제 값으로 채움
#   PINVI_ENV_FILE=infra/.env.prod scripts/deploy-node.sh deploy
#   (또는 운영 노드 /opt/pinvi/.env 로 복사 — compose는 cwd의 .env를 자동 로드)

# canonical 값만 허용: development | test | smoke | staging | production
PINVI_ENVIRONMENT=production

# ── 도메인 (reverse proxy → 로컬 고정 포트) ──────────────────────────────
#   web      → :12805   |  api  → :12801  |  dagster → :12802
#   grafana  → :12205
#   s3 api   → RustFS API :12101 (presigned 서명 host)
#   s3 콘솔  → RustFS console :12105 (reverse proxy 전용, app env 아님)
PINVI_WEB_BASE_URL=https://pinvi.example.com
PINVI_DAGSTER_BASE_URL=https://dagster.example.com
PINVI_OAUTH_CALLBACK_BASE_URL=https://pinvi-api.example.com
PINVI_CORS_ALLOWED_ORIGINS=["https://pinvi.example.com"]
NEXT_PUBLIC_PINVI_API_URL=https://pinvi-api.example.com
NEXT_PUBLIC_PINVI_ENV=production
NEXT_PUBLIC_GRAFANA_URL=https://grafana.example.com
NEXT_PUBLIC_GRAFANA_DASHBOARD_PATH=/d/pinvi/overview?orgId=1&kiosk=tv
EXPO_PUBLIC_PINVI_API_URL=https://pinvi-api.example.com

# ── RustFS ───────────────────────────────────────────────────────────────
# 서버→RustFS 내부 endpoint는 compose 내부망(app-rustfs:9000) 유지.
# 브라우저 presigned 서명 host = public endpoint = s3 api 도메인.
PINVI_RUSTFS_PUBLIC_ENDPOINT_URL=https://s3-api.example.com
PINVI_RUSTFS_PUBLIC_BASE_URL=https://s3-api.example.com

# ── 관측/운영 ────────────────────────────────────────────────────────────
PINVI_SENTRY_ENVIRONMENT=production
PINVI_RATE_LIMIT_BACKEND=postgres
# kor-travel-map canonical admin ops. URL은 허용 host의 :12701 root만, 실제 token 두 값은
# 서로 달라야 하며 32자 이상이고 Unicode whitespace를 포함하면 안 된다.
PINVI_KOR_TRAVEL_MAP_ADMIN_BASE_URL=http://host.docker.internal:12701
PINVI_KOR_TRAVEL_MAP_OPS_READ_TOKEN=change-me-read-token-at-least-32-characters
PINVI_KOR_TRAVEL_MAP_OPS_CANCEL_TOKEN=change-me-cancel-token-at-least-32-characters
# ADR-035: Trip WebSocket broker는 process-local in-memory다. shared broker 전환 전까지 1 유지.
PINVI_API_WORKERS=1
PINVI_GRAFANA_PORT=12205
PINVI_GRAFANA_ADMIN_USER=admin
PINVI_GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# ── 한국 전용 geofencing (ADR-018) ──────────────────────────────────────
# 운영 edge(Cloudflare/nginx/HAProxy)가 CF-IPCountry와 trusted proxy signal을 API로 전달할 때만
# true로 전환한다. PINVI_GEOFENCE_BLOCK_UNKNOWN=true는 trusted signal 누락 트래픽을 451로
# 차단하므로, edge header 주입을 먼저 검증한다.
PINVI_GEOFENCE_ENABLED=false
PINVI_GEOFENCE_ALLOWED_COUNTRIES=["KR"]
PINVI_GEOFENCE_COUNTRY_HEADER=CF-IPCountry
PINVI_GEOFENCE_TRUSTED_PROXY_HEADER=X-Pinvi-Geofence-Proxy
PINVI_GEOFENCE_TRUSTED_PROXY_SECRET=
PINVI_GEOFENCE_TRUSTED_PROXY_CIDRS=[]
PINVI_GEOFENCE_MTLS_VERIFIED_HEADER=
PINVI_GEOFENCE_MTLS_VERIFIED_VALUE=SUCCESS
PINVI_GEOFENCE_BLOCK_UNKNOWN=false
PINVI_GEOFENCE_BYPASS_PATHS=["/health","/health/db","/metrics","/docs","/redoc","/openapi.json"]

# ── 이미지 tag (deploy.md §1·§2) ─────────────────────────────────────────
# 운영 노드에서 ktdctl이 ~/pinvi 소스로 로컬 빌드한다(GHCR 미사용). kor-travel-* 스택과 동일.
PINVI_API_IMAGE=pinvi-api:latest-main
PINVI_WEB_IMAGE=pinvi-web:latest-main
PINVI_DAGSTER_IMAGE=pinvi-dagster:latest-main
# PINVI_SOURCE_REVISION은 파일에 고정하지 않는다. production build wrapper/ktdctl이 clean
# PinVi source HEAD에서 계산해 Docker build arg로 전달하고 image OCI label과 대조한다.

# ── 시크릿 — 운영 실제 값으로 채울 것(예시 값 금지) ──────────────────────
PINVI_POSTGRES_PASSWORD=change-me
PINVI_DATABASE_URL=postgresql+asyncpg://pinvi:change-me@app-postgres:5432/pinvi
PINVI_JWT_SECRET_KEY=change-me-32-bytes-minimum-secret
PINVI_MCP_JWT_SECRET=change-me-32-bytes-minimum-secret
# 첫 운영 진입용 bootstrap admin. 최초 로그인/실계정 승격 후에는
# PINVI_BOOTSTRAP_ADMIN_PASSWORD를 비우고 기본 계정을 비활성화한다.
PINVI_BOOTSTRAP_ADMIN_EMAIL=bootstrap-admin@example.com
PINVI_BOOTSTRAP_ADMIN_PASSWORD=change-me-bootstrap-password
PINVI_RESEND_API_KEY=
# 서버 VWorld key. 모바일 `/mobile/vworld/token` 발급과 kor-travel-geo v2 REST `key`
# query에 같은 값을 사용한다(ADR-048). kor-travel-geo 쪽 `KTG_VWORLD_API_KEY`도 같은
# 값으로 설정하고, 그 서비스가 공개 API key hash 저장/검증을 소유한다.
PINVI_VWORLD_API_KEY=
NEXT_PUBLIC_VWORLD_API_KEY=
DATA_GO_KR_SERVICE_KEY=
