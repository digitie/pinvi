# apps/api 전용 환경변수 — 루트 .env.example을 참고하여 채울 것.
# 본 파일은 컨테이너/로컬 dev 시 `dotenv_path`로 사용.

TRIPMATE_ENVIRONMENT=development
TRIPMATE_DATABASE_URL=postgresql+asyncpg://tripmate:tripmate_dev_password@localhost:55432/tripmate
TRIPMATE_DATABASE_POOL_SIZE=10
TRIPMATE_JWT_SECRET_KEY=tripmate-local-jwt-secret-change-me
TRIPMATE_ACCESS_TOKEN_MINUTES=15
TRIPMATE_REFRESH_TOKEN_DAYS=7
TRIPMATE_WEB_BASE_URL=http://localhost:9022
# production: TRIPMATE_WEB_BASE_URL=https://tripmate.digitie.mywire.org
TRIPMATE_EMAIL_VERIFICATION_PATH=/verify-email
TRIPMATE_RESEND_API_KEY=
TRIPMATE_RESEND_FROM_EMAIL=TripMate <noreply@send.tripmate.local>
TRIPMATE_RESEND_WEBHOOK_SECRET=
# 로컬 개발 전용. 운영/스테이징은 secret 설정 후 false/미설정 유지.
TRIPMATE_RESEND_WEBHOOK_ALLOW_UNSIGNED=true
TRIPMATE_CORS_ALLOWED_ORIGINS=["http://localhost:9022","http://127.0.0.1:9022"]
# production: TRIPMATE_CORS_ALLOWED_ORIGINS=["https://tripmate.digitie.mywire.org"]
TRIPMATE_GEOFENCE_TRUSTED_PROXY_HEADER=X-TripMate-Geofence-Proxy
TRIPMATE_GEOFENCE_TRUSTED_PROXY_SECRET=
TRIPMATE_GEOFENCE_TRUSTED_PROXY_CIDRS=[]
TRIPMATE_GEOFENCE_MTLS_VERIFIED_HEADER=
TRIPMATE_GEOFENCE_MTLS_VERIFIED_VALUE=SUCCESS
TRIPMATE_WS_CLIENT_RATE_PER_SECOND=5
TRIPMATE_WS_CLIENT_RATE_PER_MINUTE=60
TRIPMATE_WS_RATE_LIMIT_CLOSE_GRACE_SECONDS=30
TRIPMATE_WS_MAX_CONNECTIONS_PER_TRIP=10
TRIPMATE_WS_MAX_CONNECTIONS_TOTAL=200
TRIPMATE_WS_SEND_TIMEOUT_SECONDS=2
TRIPMATE_OAUTH_CALLBACK_BASE_URL=http://localhost:9021
# production: TRIPMATE_OAUTH_CALLBACK_BASE_URL=https://tripmateapi.digitie.mywire.org
