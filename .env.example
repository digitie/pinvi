# Pinvi v2 환경변수 예시
# 운영 / staging 값은 별도 secret 저장소. 본 파일은 키 이름 + 안전한 기본값만.
# 운영(prod) 전체 override 세트는 `infra/.env.prod.example`(placeholder) 참고.
# 실제 도메인/시크릿은 gitignore된 `infra/.env.prod`에만 둔다(공개 repo 커밋 금지, ADR-047).

# ─────────────────────────────────────────────────────────────
# 0. Local dev fixed ports
# ─────────────────────────────────────────────────────────────
PINVI_API_DEV_PORT=12801
PINVI_WEB_DEV_PORT=12805
PINVI_DAGSTER_DEV_PORT=12802
PINVI_DAGSTER_BASE_URL=http://localhost:12802

# ─────────────────────────────────────────────────────────────
# 1. 인증 / JWT
# ─────────────────────────────────────────────────────────────
PINVI_JWT_SECRET_KEY=pinvi-local-jwt-secret-change-me
PINVI_ACCESS_TOKEN_MINUTES=10
PINVI_REFRESH_TOKEN_DAYS=7
PINVI_ADMIN_SESSION_TTL=3600
PINVI_MCP_JWT_SECRET=pinvi-local-mcp-secret-change-me
PINVI_MCP_TOKEN_DEFAULT_DAYS=30
PINVI_MCP_RATE_LIMIT_PER_MINUTE=60

# ─────────────────────────────────────────────────────────────
# 2. Database
# ─────────────────────────────────────────────────────────────
# 로컬: 5432 host port (compose) → 5432 컨테이너 internal
PINVI_DATABASE_URL=postgresql+asyncpg://pinvi:pinvi_dev_password@localhost:5432/pinvi
PINVI_DATABASE_POOL_SIZE=10

# ─────────────────────────────────────────────────────────────
# 3. Resend (이메일)
# ─────────────────────────────────────────────────────────────
# 빈 값이면 콘솔 출력 모드 — 가입은 성공하지만 verification_email_dispatched=false
PINVI_RESEND_API_KEY=
PINVI_RESEND_API_BASE_URL=https://api.resend.com
PINVI_RESEND_FROM_EMAIL=Pinvi <noreply@send.pinvi.local>
PINVI_RESEND_TIMEOUT_SECONDS=5
PINVI_RESEND_WEBHOOK_SECRET=
# 기본 false(안전). 로컬에서 서명 없이 테스트할 때만 true로. 운영/스테이징은 false 유지.
PINVI_RESEND_WEBHOOK_ALLOW_UNSIGNED=false
# FastAPI lifespan에서 email_queue drain worker를 실행한다. 여러 API worker가 떠도
# `FOR UPDATE SKIP LOCKED`로 중복 발송을 막는다.
PINVI_EMAIL_OUTBOX_WORKER_ENABLED=true
PINVI_EMAIL_OUTBOX_DRAIN_INTERVAL_SECONDS=5
PINVI_EMAIL_OUTBOX_BATCH_SIZE=50
PINVI_WEB_BASE_URL=http://localhost:12805
# production: PINVI_WEB_BASE_URL=https://pinvi.example.com
PINVI_EMAIL_VERIFICATION_PATH=/verify-email
PINVI_PASSWORD_RESET_PATH=/reset-password

# ─────────────────────────────────────────────────────────────
# 4. OAuth (소셜 로그인 — Google/Naver/Kakao)
# ─────────────────────────────────────────────────────────────
PINVI_GOOGLE_OAUTH_CLIENT_ID=
PINVI_GOOGLE_OAUTH_CLIENT_SECRET=
PINVI_NAVER_OAUTH_CLIENT_ID=
PINVI_NAVER_OAUTH_CLIENT_SECRET=
PINVI_KAKAO_OAUTH_REST_API_KEY=
# Kakao client secret은 앱 설정에서 활성화한 경우에만 token exchange에 전달된다.
PINVI_KAKAO_OAUTH_CLIENT_SECRET=
PINVI_OAUTH_CALLBACK_BASE_URL=http://localhost:12801
# production: PINVI_OAUTH_CALLBACK_BASE_URL=https://pinvi-api.example.com
PINVI_OAUTH_STATE_TTL_SECONDS=600
PINVI_OAUTH_HTTP_TIMEOUT_SECONDS=5

# ─────────────────────────────────────────────────────────────
# 5. RustFS (S3 호환 객체 저장소)
# ─────────────────────────────────────────────────────────────
PINVI_RUSTFS_PORT=12101
PINVI_RUSTFS_CONSOLE_PORT=12105
PINVI_RUSTFS_ENDPOINT_URL=http://localhost:12101
# 서버→RustFS 내부 endpoint. docker prod는 http://app-rustfs:9000 (compose 기본값).
PINVI_RUSTFS_PUBLIC_ENDPOINT_URL=http://127.0.0.1:12101
# 브라우저 presigned 서명 host. production: PINVI_RUSTFS_PUBLIC_ENDPOINT_URL=https://s3-api.example.com
PINVI_RUSTFS_BUCKET=pinvi-media
PINVI_RUSTFS_ACCESS_KEY_ID=rustfsadmin
PINVI_RUSTFS_SECRET_ACCESS_KEY=rustfsadmin
PINVI_RUSTFS_PRESIGNED_URL_EXPIRES_SECONDS=900
PINVI_RUSTFS_MAX_UPLOAD_BYTES=10485760
PINVI_RUSTFS_ALLOWED_CONTENT_TYPES=["image/jpeg","image/png","image/webp","image/gif","video/mp4","application/pdf"]
PINVI_RUSTFS_PUBLIC_BASE_URL=

# ─────────────────────────────────────────────────────────────
# 6. kor-travel-map 독립 프로그램 (지도 feature OpenAPI/Admin)
# ─────────────────────────────────────────────────────────────
PINVI_KOR_TRAVEL_MAP_API_BASE_URL=http://localhost:12701
# admin feature change(/v1/admin/features*)도 같은 호스트 :12701
PINVI_KOR_TRAVEL_MAP_ADMIN_BASE_URL=http://localhost:12701
# 운영 인증은 인프라 계층. 설정 시 X-Kor-Travel-Map-Service-Token 헤더로 전달.
PINVI_KOR_TRAVEL_MAP_SERVICE_TOKEN=
# public REST의 X-Kor-Travel-Map-Api-Key 헤더. 미설정 시 PINVI_VWORLD_API_KEY fallback.
PINVI_KOR_TRAVEL_MAP_PUBLIC_API_KEY=
# admin-path 전용 토큰(미설정 시 위 SERVICE_TOKEN fallback).
PINVI_KOR_TRAVEL_MAP_ADMIN_SERVICE_TOKEN=
# kor-travel-map ADR-060 admin proxy gate가 켜진 운영 API용 server-only secret/actor.
PINVI_KOR_TRAVEL_MAP_ADMIN_PROXY_SECRET=
PINVI_KOR_TRAVEL_MAP_ADMIN_ACTOR=pinvi-admin
# canonical /v1/ops/datasets*·/v1/ops/pipeline* scope별 service principal.
PINVI_KOR_TRAVEL_MAP_OPS_READ_TOKEN=
PINVI_KOR_TRAVEL_MAP_OPS_CANCEL_TOKEN=
PINVI_KOR_TRAVEL_MAP_TIMEOUT_SECONDS=5
PINVI_KOR_TRAVEL_MAP_MAX_ATTEMPTS=3
PINVI_KOR_TRAVEL_MAP_BATCH_CHUNK_SIZE=200

# ─────────────────────────────────────────────────────────────
# 6-1. kor-travel-geo v2 REST (주소/좌표/행정구역)
# ─────────────────────────────────────────────────────────────
PINVI_KOR_TRAVEL_GEO_BASE_URL=http://localhost:12501
PINVI_KOR_TRAVEL_GEO_TIMEOUT_SECONDS=5
PINVI_KOR_TRAVEL_GEO_MAX_ATTEMPTS=3

# VWorld 지도 키 (서버) — 모바일 앱은 키를 번들하지 않고 GET /mobile/vworld/token(인증)으로
# 발급받는다(ADR-043). kor-travel-geo v2 REST는 이 값을 `key` query로 사용한다(ADR-048).
# kor-travel-map의 전용 public key가 비어 있을 때도 값만 fallback으로 재사용하되, Map에는
# `X-Kor-Travel-Map-Api-Key` 헤더로 전송한다. 미설정 시 모바일 token endpoint와 Pinvi geocoding
# 호출은 503 계열로 degrade한다. 웹은 NEXT_PUBLIC_VWORLD_API_KEY를 사용하며 별도
# PINVI_KOR_TRAVEL_GEO_API_KEY는 두지 않는다.
PINVI_VWORLD_API_KEY=
PINVI_VWORLD_TOKEN_TTL_SECONDS=600

# ─────────────────────────────────────────────────────────────
# 7. KASI / data.go.kr (Pinvi Dagster)
# ─────────────────────────────────────────────────────────────
DATA_GO_KR_SERVICE_KEY=
PINVI_KASI_SPECIAL_DAYS_LOOKBACK_MONTHS=6
PINVI_KASI_SPECIAL_DAYS_LOOKAHEAD_MONTHS=18

# ─────────────────────────────────────────────────────────────
# 8. Sentry (에러 / 성능)
# ─────────────────────────────────────────────────────────────
PINVI_SENTRY_DSN=
PINVI_SENTRY_ENVIRONMENT=development
# production: PINVI_SENTRY_ENVIRONMENT=production
PINVI_SENTRY_RELEASE=
PINVI_SENTRY_TRACES_SAMPLE_RATE=0.1
PINVI_SENTRY_PROFILES_SAMPLE_RATE=0.0

# ─────────────────────────────────────────────────────────────
# 8-1. Prometheus / Grafana / cAdvisor (관측 스택)
# ─────────────────────────────────────────────────────────────
PINVI_PROMETHEUS_METRICS_ENABLED=true
PINVI_PROMETHEUS_METRICS_PATH=/metrics
PINVI_PROMETHEUS_EXCLUDE_PATHS=["/health","/health/db","/metrics"]
PINVI_DOCKER_SOCKET_PATH=/var/run/docker.sock
PINVI_DOCKER_STATUS_TIMEOUT_SECONDS=2
PINVI_DOCKER_STATUS_CONTAINER_LIMIT=80
PINVI_PROMETHEUS_PORT=12401
PINVI_CADVISOR_PORT=12301
PINVI_BLACKBOX_IMAGE=prom/blackbox-exporter:v0.25.0
PINVI_GRAFANA_PORT=12205
PINVI_GRAFANA_ADMIN_USER=admin
PINVI_GRAFANA_ADMIN_PASSWORD=admin

# ─────────────────────────────────────────────────────────────
# 8-2. HTTP Rate limit (ADR-038)
# ─────────────────────────────────────────────────────────────
PINVI_RATE_LIMIT_ENABLED=true
PINVI_RATE_LIMIT_BACKEND=auto
# 운영/스테이징 auto=postgres, dev/test/smoke auto=memory. 운영에서 임의 memory 금지.
PINVI_RATE_LIMIT_FAIL_OPEN=false
PINVI_RATE_LIMIT_WINDOW_SECONDS=60
PINVI_RATE_LIMIT_PUBLIC_PER_MINUTE=60
PINVI_RATE_LIMIT_AUTHENTICATED_PER_MINUTE=60
PINVI_RATE_LIMIT_AUTH_PER_MINUTE=5
PINVI_RATE_LIMIT_OAUTH_PER_MINUTE=10
PINVI_RATE_LIMIT_STORAGE_UPLOAD_PER_MINUTE=30
PINVI_RATE_LIMIT_FEATURE_SEARCH_PER_MINUTE=60
PINVI_RATE_LIMIT_TRIP_EXPORT_PER_MINUTE=20
PINVI_RATE_LIMIT_SHARED_TOKEN_PER_MINUTE=60
PINVI_RATE_LIMIT_BODY_PEEK_MAX_BYTES=65536
# Cloudflare/reverse proxy가 origin 직접 접근을 막는 환경에서만 CF-Connecting-IP 등으로 설정.
PINVI_RATE_LIMIT_CLIENT_IP_HEADER=
PINVI_RATE_LIMIT_BYPASS_PATHS=["/health","/health/db","/metrics","/docs","/redoc","/openapi.json"]

# ─────────────────────────────────────────────────────────────
# 9. CORS
# ─────────────────────────────────────────────────────────────
# JSON 배열 — 빈 값이면 dev 기본값(localhost:12805) 사용
PINVI_CORS_ALLOWED_ORIGINS=["http://localhost:12805","http://127.0.0.1:12805"]
# production: PINVI_CORS_ALLOWED_ORIGINS=["https://pinvi.example.com"]

# ─────────────────────────────────────────────────────────────
# 10. Geofencing (ADR-018, FastAPI 3차 fallback)
# ─────────────────────────────────────────────────────────────
PINVI_GEOFENCE_ENABLED=false
PINVI_GEOFENCE_ALLOWED_COUNTRIES=["KR"]
PINVI_GEOFENCE_COUNTRY_HEADER=CF-IPCountry
PINVI_GEOFENCE_TRUSTED_PROXY_HEADER=X-Pinvi-Geofence-Proxy
PINVI_GEOFENCE_TRUSTED_PROXY_SECRET=
PINVI_GEOFENCE_TRUSTED_PROXY_CIDRS=[]
PINVI_GEOFENCE_MTLS_VERIFIED_HEADER=
PINVI_GEOFENCE_MTLS_VERIFIED_VALUE=SUCCESS
PINVI_GEOFENCE_BLOCK_UNKNOWN=false
PINVI_GEOFENCE_BYPASS_PATHS=["/health","/health/db","/metrics","/docs","/redoc","/openapi.json"]

# ─────────────────────────────────────────────────────────────
# 11. Backup / Restore (ADR-022, app schema snapshot)
# ─────────────────────────────────────────────────────────────
PINVI_BACKUP_DIR=.tmp/backups
PINVI_BACKUP_SCRIPT_PATH=scripts/backup-db.sh
PINVI_RESTORE_SCRIPT_PATH=scripts/restore-db.sh
PINVI_RESTORE_HOTSWAP_SCRIPT_PATH=scripts/restore-hotswap.sh
PINVI_BACKUP_TIMEOUT_SECONDS=900
PINVI_RESTORE_TIMEOUT_SECONDS=3600
PINVI_BACKUP_SCHEMA=app
# scripts/restore-staging-drill.sh 전용. 실제 staging DB URL은 로컬 비추적 env에만 둔다.
PINVI_RESTORE_STAGING_DATABASE_URL=
PINVI_RESTORE_DATABASE_URL=
# 실제 schema-swap 실행은 staging drill 후 운영 노드에서만 1로 둔다.
PINVI_RESTORE_HOTSWAP_EXECUTE=0
PINVI_RESTORE_DRAIN_COMMAND=
PINVI_RESTORE_ALLOW_NO_DRAIN=0
PINVI_RESTORE_APP_ROLE=

# ─────────────────────────────────────────────────────────────
# 12. Frontend (apps/web, NEXT_PUBLIC_* 는 빌드 시 embed)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_PINVI_API_URL=http://localhost:12801
# production build: NEXT_PUBLIC_PINVI_API_URL=https://pinvi-api.example.com
NEXT_PUBLIC_PINVI_ENV=development
# production: NEXT_PUBLIC_PINVI_ENV=production
NEXT_PUBLIC_PINVI_RESTORE_HOTSWAP_UI_ENABLED=0
# staging drill에서 UI restore 버튼을 열 때만 1. production 기본값은 0.
NEXT_PUBLIC_VWORLD_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GRAFANA_URL=http://localhost:12205
# production: NEXT_PUBLIC_GRAFANA_URL=https://grafana.example.com
PINVI_GRAFANA_HEALTH_URL=http://localhost:12205
# app compose internal probe: PINVI_GRAFANA_HEALTH_URL=http://grafana:3000
NEXT_PUBLIC_GRAFANA_DASHBOARD_PATH=/d/pinvi/overview?orgId=1&kiosk=tv

# ─────────────────────────────────────────────────────────────
# 12.1 Mobile Expo Dev Client (apps/mobile, ADR-043)
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_PINVI_API_URL=http://localhost:12801
# production: EXPO_PUBLIC_PINVI_API_URL=https://pinvi-api.example.com
# 모바일 앱에는 EXPO_PUBLIC_VWORLD_API_KEY를 두지 않는다(ADR-043).
# VWorld 키는 서버 PINVI_VWORLD_API_KEY를 GET /mobile/vworld/token(인증)으로 발급한다.

# ─────────────────────────────────────────────────────────────
# 13. Bootstrap admin (선택)
# ─────────────────────────────────────────────────────────────
# 비밀번호가 비어 있으면 startup bootstrap은 실행되지 않는다.
# 실제 임시 비밀번호는 로컬/운영 gitignore env에만 둔다.
PINVI_BOOTSTRAP_ADMIN_EMAIL=bootstrap-admin@example.com
PINVI_BOOTSTRAP_ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────
# 14. Feature flags
# ─────────────────────────────────────────────────────────────
PINVI_ENABLE_SEED=false
# development | test | smoke | staging | production (별칭/공백 값 금지)
PINVI_ENVIRONMENT=development
