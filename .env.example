# TripMate v2 환경변수 예시
# 운영 / staging 값은 별도 secret 저장소. 본 파일은 키 이름 + 안전한 기본값만.

# ─────────────────────────────────────────────────────────────
# 0. Local dev fixed ports
# ─────────────────────────────────────────────────────────────
TRIPMATE_API_DEV_PORT=9021
TRIPMATE_WEB_DEV_PORT=9022
TRIPMATE_DAGSTER_DEV_PORT=9023

# ─────────────────────────────────────────────────────────────
# 1. 인증 / JWT
# ─────────────────────────────────────────────────────────────
TRIPMATE_JWT_SECRET_KEY=tripmate-local-jwt-secret-change-me
TRIPMATE_ACCESS_TOKEN_MINUTES=15
TRIPMATE_REFRESH_TOKEN_DAYS=7
TRIPMATE_ADMIN_SESSION_TTL=3600

# ─────────────────────────────────────────────────────────────
# 2. Database
# ─────────────────────────────────────────────────────────────
# 로컬: 55432 host port (compose) → 5432 컨테이너 internal
TRIPMATE_DATABASE_URL=postgresql+asyncpg://tripmate:tripmate_dev_password@localhost:55432/tripmate
TRIPMATE_DATABASE_POOL_SIZE=10

# ─────────────────────────────────────────────────────────────
# 3. Resend (이메일)
# ─────────────────────────────────────────────────────────────
# 빈 값이면 콘솔 출력 모드 — 가입은 성공하지만 verification_email_dispatched=false
TRIPMATE_RESEND_API_KEY=
TRIPMATE_RESEND_FROM_EMAIL=TripMate <noreply@send.tripmate.local>
TRIPMATE_RESEND_TIMEOUT_SECONDS=5
TRIPMATE_RESEND_WEBHOOK_SECRET=
TRIPMATE_WEB_BASE_URL=http://localhost:9022
TRIPMATE_EMAIL_VERIFICATION_PATH=/verify-email

# ─────────────────────────────────────────────────────────────
# 4. OAuth (소셜 로그인)
# ─────────────────────────────────────────────────────────────
TRIPMATE_GOOGLE_OAUTH_CLIENT_ID=
TRIPMATE_GOOGLE_OAUTH_CLIENT_SECRET=
TRIPMATE_NAVER_OAUTH_CLIENT_ID=
TRIPMATE_NAVER_OAUTH_CLIENT_SECRET=
TRIPMATE_KAKAO_OAUTH_REST_API_KEY=
TRIPMATE_KAKAO_OAUTH_CLIENT_SECRET=
TRIPMATE_OAUTH_CALLBACK_BASE_URL=http://localhost:9021
TRIPMATE_OAUTH_STATE_TTL_SECONDS=600
TRIPMATE_OAUTH_HTTP_TIMEOUT_SECONDS=5

# ─────────────────────────────────────────────────────────────
# 5. RustFS (S3 호환 객체 저장소)
# ─────────────────────────────────────────────────────────────
TRIPMATE_RUSTFS_PORT=9003
TRIPMATE_RUSTFS_CONSOLE_PORT=9004
TRIPMATE_RUSTFS_ENDPOINT_URL=http://localhost:9003
TRIPMATE_RUSTFS_PUBLIC_ENDPOINT_URL=http://127.0.0.1:9003
TRIPMATE_RUSTFS_BUCKET=tripmate-media
TRIPMATE_RUSTFS_ACCESS_KEY_ID=tripmate-dev-access
TRIPMATE_RUSTFS_SECRET_ACCESS_KEY=tripmate-dev-secret-change-me
TRIPMATE_RUSTFS_PRESIGNED_URL_EXPIRES_SECONDS=900
TRIPMATE_RUSTFS_MAX_UPLOAD_BYTES=10485760
TRIPMATE_RUSTFS_ALLOWED_CONTENT_TYPES=["image/jpeg","image/png","image/webp","image/gif","video/mp4","application/pdf"]

# ─────────────────────────────────────────────────────────────
# 6. krtour-map 독립 프로그램 (지도 feature OpenAPI/Admin)
# ─────────────────────────────────────────────────────────────
TRIPMATE_KRTOUR_MAP_API_BASE_URL=http://localhost:9011
TRIPMATE_KRTOUR_MAP_ADMIN_BASE_URL=http://localhost:9012

# ─────────────────────────────────────────────────────────────
# 7. Sentry (에러 / 성능)
# ─────────────────────────────────────────────────────────────
TRIPMATE_SENTRY_DSN=
TRIPMATE_SENTRY_ENVIRONMENT=development
TRIPMATE_SENTRY_RELEASE=
TRIPMATE_SENTRY_TRACES_SAMPLE_RATE=0.1
TRIPMATE_SENTRY_PROFILES_SAMPLE_RATE=0.0

# ─────────────────────────────────────────────────────────────
# 8. CORS
# ─────────────────────────────────────────────────────────────
# JSON 배열 — 빈 값이면 dev 기본값(localhost:9022) 사용
TRIPMATE_CORS_ALLOWED_ORIGINS=["http://localhost:9022","http://127.0.0.1:9022"]

# ─────────────────────────────────────────────────────────────
# 9. Frontend (apps/web, NEXT_PUBLIC_* 는 빌드 시 embed)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_TRIPMATE_API_URL=http://localhost:9021
NEXT_PUBLIC_TRIPMATE_ENV=development
NEXT_PUBLIC_VWORLD_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────
# 10. Bootstrap admin (선택)
# ─────────────────────────────────────────────────────────────
TRIPMATE_BOOTSTRAP_ADMIN_EMAIL=admin@ad.min
TRIPMATE_BOOTSTRAP_ADMIN_PASSWORD=admin

# ─────────────────────────────────────────────────────────────
# 11. Feature flags
# ─────────────────────────────────────────────────────────────
TRIPMATE_ENABLE_SEED=false
TRIPMATE_ENVIRONMENT=development
