# Pinvi 운영(prod) env 템플릿 — placeholder만. 실제 값은 `infra/.env.prod`(gitignore)에 둔다.
# 공개 repo에는 실제 도메인/시크릿을 커밋하지 않는다(ADR-047).
#
# 사용:
#   cp infra/.env.prod.example infra/.env.prod   # 후 실제 값으로 채움
#   PINVI_ENV_FILE=infra/.env.prod scripts/deploy-node.sh deploy
#   (또는 운영 노드 /opt/pinvi/.env 로 복사 — compose는 cwd의 .env를 자동 로드)

PINVI_ENVIRONMENT=production

# ── 도메인 (reverse proxy → 로컬 고정 포트) ──────────────────────────────
#   web      → :12805   |  api  → :12801  |  dagster → :12802
#   s3 api   → RustFS API :12101 (presigned 서명 host)
#   s3 콘솔  → RustFS console :12105 (reverse proxy 전용, app env 아님)
PINVI_WEB_BASE_URL=https://pinvi.example.com
PINVI_OAUTH_CALLBACK_BASE_URL=https://pinvi-api.example.com
PINVI_CORS_ALLOWED_ORIGINS=["https://pinvi.example.com"]
NEXT_PUBLIC_PINVI_API_URL=https://pinvi-api.example.com
NEXT_PUBLIC_PINVI_ENV=production
EXPO_PUBLIC_PINVI_API_URL=https://pinvi-api.example.com

# ── RustFS ───────────────────────────────────────────────────────────────
# 서버→RustFS 내부 endpoint는 compose 내부망(app-rustfs:9000) 유지.
# 브라우저 presigned 서명 host = public endpoint = s3 api 도메인.
PINVI_RUSTFS_PUBLIC_ENDPOINT_URL=https://s3-api.example.com
PINVI_RUSTFS_PUBLIC_BASE_URL=https://s3-api.example.com

# ── 관측/운영 ────────────────────────────────────────────────────────────
PINVI_SENTRY_ENVIRONMENT=production
PINVI_RATE_LIMIT_BACKEND=postgres

# ── 이미지 tag (deploy.md §2) ────────────────────────────────────────────
PINVI_API_IMAGE=ghcr.io/digitie/pinvi-api:v0.1.0
PINVI_WEB_IMAGE=ghcr.io/digitie/pinvi-web:v0.1.0

# ── 시크릿 — 운영 실제 값으로 채울 것(예시 값 금지) ──────────────────────
PINVI_POSTGRES_PASSWORD=change-me
PINVI_DATABASE_URL=postgresql+asyncpg://pinvi:change-me@app-postgres:5432/pinvi
PINVI_JWT_SECRET_KEY=change-me-32-bytes-minimum-secret
PINVI_MCP_JWT_SECRET=change-me-32-bytes-minimum-secret
PINVI_RESEND_API_KEY=
# 서버 VWorld key. 모바일 `/mobile/vworld/token` 발급과 kor-travel-geo v2 REST `key`
# query에 같은 값을 사용한다(ADR-048). kor-travel-geo 쪽 `KTG_VWORLD_API_KEY`도 같은
# 값으로 설정하고, 그 서비스가 공개 API key hash 저장/검증을 소유한다.
PINVI_VWORLD_API_KEY=
NEXT_PUBLIC_VWORLD_API_KEY=
DATA_GO_KR_SERVICE_KEY=
